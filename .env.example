# ================================================================ 
# Shared credentials 
# ================================================================
# MySQL credentials
DB_USERNAME=replace_me
DB_PASSWORD=replace_me
JPA_DDL_AUTO=validate

# RabbitMQ credentials
RABBITMQ_USERNAME=replace_me
RABBITMQ_PASSWORD=replace_me

# Security secrets
JWT_SECRET=replace_with_base64_or_long_random_secret
INTERNAL_SERVICE_SECRET=replace_with_long_random_secret

# =================================================================
# Frontend variables 
# =================================================================
FRONTEND_BASE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# =================================================================
# Gateway variables
# =================================================================
GATEWAY_BASE_URL=http://localhost:8080
GATEWAY_PORT=8080
AUTH_SERVICE_BASE_URL=http://localhost:8090

# ================================================================= 
# Users service variables
# =================================================================
USERS_SERVICE_BASE_URL=http://localhost:8090
USERS_SERVICE_PORT=8090

# ================================================================= 
# Bar service variables
# =================================================================
BAR_SERVICE_BASE_URL=http://localhost:8081
BAR_SERVICE_PORT=8081
EVENT_PLANNER_BASE_URL=http://localhost:8082
WAREHOUSE_SERVICE_BASE_URL=http://localhost:8085
BAR_BOOTSTRAP_ENABLE_FALLBACK_DATA=false
FEATURE_EVENT_COMPLETED_ENABLED=false

# =================================================================
# Event planner service variables
# =================================================================
EVENT_PLANNER_SERVICE_BASE_URL=http://localhost:8082
EVENT_PLANNER_SERVICE_PORT=8082

# =================================================================
# Drop-points service variables
# =================================================================
DROPPOINT_SERVICE_BASE_URL=http://localhost:8083
DROPPOINT_SERVICE_PORT=8083

# =================================================================
# Warehouse service variables
# =================================================================
WAREHOUSE_SERVICE_BASE_URL=http://localhost:8085
WAREHOUSE_SERVICE_PORT=8085

# =================================================================
# Infrastructure server variables
# =================================================================
# config server
CONFIG_SERVER_BASE_URL=http://localhost:8888
CONFIG_SERVER_PORT=8888
CONFIG_REPO_GIT_URI=https://github.com/m-ali-moradi/nextBar
CONFIG_REPO_GIT_SEARCH_PATHS=config-repo
CONFIG_REPO_GIT_DEFAULT_LABEL=main
CONFIG_REPO_GIT_USERNAME=
CONFIG_REPO_GIT_TOKEN=replace_with_github_pat
# eureka server
EUREKA_SERVER_BASE_URL=http://localhost:8761
EUREKA_SERVER_PORT=8761
# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
# Zipkin tracing
ZIPKIN_BASE_URL=http://localhost:9411/api/v2/spans
ZIPKIN_PORT=9411
# Grafana: visualization tool for monitoring and observability
GRAFANA_BASE_URL=http://localhost:3000
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_me
# Prometheus: scraping and storing metrics for monitoring and alerting
PROMETHEUS_BASE_URL=http://localhost:9090
PROMETHEUS_PORT=9090
# Loki: log aggregation system for collecting and querying logs
LOKI_BASE_URL=http://localhost:3100
LOKI_PORT=3100
