context WarehouseContext {
  structure BeverageStock<entity> {
    long    id<identifier>,
    string  beverageType,
    int     quantity
  }

  structure BarDto {
   string id,
   string name,
   string location,
   int maxCapacity
  }

  structure SupplyItemDto {
    string productId,
    string productName,
    int quantity
  }

  structure SupplyRequestDto {
    string id,
    string barId,
    string status,
    string createdAt
  }

  structure ReplenishRequest {
    string beverageType,
    int quantity
  }
  structure ReplenishResponse {
    string barId,
    string requestId,
    int quantitySent,
    string message
  }
  structure DropPointRecord<entity> {
    long   id<identifier>,
    string location,
    int    currentEmpties,
    DropPointStatus status
  }

  structure EmptyBottleStock<entity> {
    long   id<identifier>,
    long   dropPointId,
    string dropPointLocation,
    int    quantity
  }

  enum DropPointStatus {
    NOTIFIED,
    ACCEPTED,
    STATUS_RESET
  }
}
